FROM node:22-alpine

# Git for commit/push. ca-certificates for HTTPS to GitHub.
RUN apk add --no-cache git ca-certificates

# Claude Code CLI (talks to DeepSeek via Anthropic-compatible API)
RUN npm install -g @anthropic-ai/claude-code

# Non-root user — Claude refuses --dangerously-skip-permissions as root.
RUN adduser -D -h /app consumer
USER consumer

WORKDIR /app

# Full codebase so Claude can fix anything — frontend, backend, scripts, docs.
COPY --chown=consumer:consumer package.json package-lock.json ./
COPY --chown=consumer:consumer scripts/ ./scripts/
COPY --chown=consumer:consumer web/ ./web/
COPY --chown=consumer:consumer server/ ./server/
COPY --chown=consumer:consumer relay/ ./relay/
COPY --chown=consumer:consumer .github/ ./.github/
COPY --chown=consumer:consumer README.md Caddyfile docker-compose.yml Dockerfile ./ 2>/dev/null || true
COPY --chown=consumer:consumer testing/ ./testing/ 2>/dev/null || true
